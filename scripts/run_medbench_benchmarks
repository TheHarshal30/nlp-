#!/usr/bin/env python3
import argparse
import json
import traceback
from pathlib import Path

from embedding_training_v2.src.medbench_integration import (
    MedBenchIntegrationError,
    aggregate_results,
    prepare_models,
    run_benchmark,
    validate_preflight,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Prepare, validate, and benchmark embedding exports in MedBench.")
    parser.add_argument("--medbench-root", required=True, help="Path to the cloned medical-entity-linking repository.")
    parser.add_argument(
        "--models",
        nargs="*",
        choices=["word2vec", "word2vec_umls", "transformer", "transformer_umls"],
        default=["word2vec", "word2vec_umls", "transformer", "transformer_umls"],
        help="Subset of models to benchmark.",
    )
    parser.add_argument("--python-bin", default="python3", help="Python executable to use inside the MedBench repo.")
    parser.add_argument("--prepare-only", action="store_true", help="Prepare model directories and exit.")
    parser.add_argument("--skip-prepare", action="store_true", help="Assume model directories are already prepared.")
    parser.add_argument("--skip-run", action="store_true", help="Run preflight validation and result aggregation only.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    medbench_root = Path(args.medbench_root).resolve()
    failures: dict[str, dict[str, str]] = {}

    try:
        prepared = (
            {model: medbench_root / "models" / model for model in args.models}
            if args.skip_prepare
            else prepare_models(medbench_root, args.models)
        )
    except Exception as exc:
        print(f"Preparation failed: {exc}")
        return 1

    print("Prepared models:")
    for model_name, model_dir in prepared.items():
        print(f"- {model_name}: {model_dir}")

    if args.prepare_only:
        return 0

    try:
        preflight = validate_preflight(prepared)
        print("Preflight validation:")
        print(json.dumps(preflight, indent=2, sort_keys=True))
    except Exception as exc:
        print(f"Preflight validation failed: {exc}")
        return 1

    if not args.skip_run:
        for model_name in args.models:
            print(f"Running MedBench for {model_name} ...")
            try:
                run_benchmark(medbench_root, model_name, args.python_bin)
            except Exception as exc:
                failures[model_name] = {
                    "stage": "evaluation",
                    "error": str(exc),
                    "traceback": traceback.format_exc(),
                }
                print(f"{model_name}: evaluation failed: {exc}")

    try:
        aggregate = aggregate_results(medbench_root, args.models)
        print("Aggregated results written to:")
        print(f"- {medbench_root / 'results' / 'embedding_benchmark_summary.json'}")
        print(f"- {medbench_root / 'results' / 'embedding_benchmark_summary.md'}")
        for model_name, payload in aggregate.items():
            summary = payload["summary"]
            print(f"{model_name}: EL={summary['Entity Linking']} | STS={summary['STS']} | NLI={summary['NLI']}")
    except Exception as exc:
        print(f"Aggregation failed: {exc}")
        return 1

    if failures:
        print("Benchmark failures:")
        print(json.dumps(failures, indent=2, sort_keys=True))
        return 1

    print("Benchmarking completed successfully.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
