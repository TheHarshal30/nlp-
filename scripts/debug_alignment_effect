#!/usr/bin/env python3
import argparse
import json
from pathlib import Path

import numpy as np

from embedding_evaluation.src.models.loader import load_embedder


DEFAULT_TEXTS = [
    "diabetes mellitus",
    "insulin therapy",
    "heart failure",
]


def cosine(a: np.ndarray, b: np.ndarray) -> float:
    denom = np.linalg.norm(a) * np.linalg.norm(b)
    if denom <= 1e-12:
        return 0.0
    return float(np.dot(a, b) / denom)


def parse_args():
    parser = argparse.ArgumentParser(description="Compare base vs projected inference for aligned embedding models.")
    parser.add_argument("--model-path", required=True, help="Path to exported model directory.")
    parser.add_argument("--model-name", default=None, help="Optional display name.")
    parser.add_argument("--text-a", default=DEFAULT_TEXTS[0])
    parser.add_argument("--text-b", default=DEFAULT_TEXTS[1])
    parser.add_argument("--text-c", default=DEFAULT_TEXTS[2], help="Optional unrelated text for contrast.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    model_name = args.model_name or Path(args.model_path).name
    texts = [args.text_a, args.text_b, args.text_c]

    base = load_embedder(args.model_path, inference={"inference_mode": "base", "use_projection": False})
    projected = load_embedder(args.model_path, inference={"inference_mode": "projected", "use_projection": True})
    base_vectors = base.encode(texts)
    projected_vectors = projected.encode(texts)

    payload = {
        "model": model_name,
        "texts": texts,
        "base_shape": list(base_vectors.shape),
        "projected_shape": list(projected_vectors.shape),
        "similarity_before": cosine(base_vectors[0], base_vectors[1]),
        "similarity_after": cosine(projected_vectors[0], projected_vectors[1]),
        "unrelated_before": cosine(base_vectors[0], base_vectors[2]),
        "unrelated_after": cosine(projected_vectors[0], projected_vectors[2]),
        "mean_abs_shift": float(np.mean(np.abs(projected_vectors - projected_vectors.mean(axis=0, keepdims=True)))),
    }
    print(f"Model: {payload['model']}")
    print(f"Similarity(before): {payload['similarity_before']:.6f}")
    print(f"Similarity(after): {payload['similarity_after']:.6f}")
    print(f"Unrelated(before): {payload['unrelated_before']:.6f}")
    print(f"Unrelated(after): {payload['unrelated_after']:.6f}")
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
