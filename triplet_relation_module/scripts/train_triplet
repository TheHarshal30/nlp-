#!/usr/bin/env python3
import argparse
import json
from pathlib import Path

from triplet_relation_module.src.training.trainer import train_triplet_model
from triplet_relation_module.src.utils.io import configure_logging, read_json, set_seed


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Train relation-aware biomedical embeddings with triplet loss.")
    parser.add_argument("--config", required=True, help="Path to triplet training config JSON.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    config = read_json(args.config)
    configure_logging()
    set_seed(config["seed"])
    summary = train_triplet_model(config)
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
