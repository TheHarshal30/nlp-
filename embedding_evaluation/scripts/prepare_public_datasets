#!/usr/bin/env python3
import argparse
import json

from embedding_evaluation.src.datasets.hf_prepare import prepare_all_public_datasets


def parse_args():
    parser = argparse.ArgumentParser(description="Download and normalize public biomedical evaluation datasets.")
    parser.add_argument(
        "--output-root",
        default="embedding_evaluation/data/public",
        help="Destination root for normalized local evaluation files.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    summary = prepare_all_public_datasets(args.output_root)
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
