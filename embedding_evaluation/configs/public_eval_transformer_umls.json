{
  "model_name": "transformer_umls",
  "model_path": "embedding_training_v2/outputs/models/transformer_umls_fast",
  "batch_size": 64,
  "smoke_limit": 256,
  "inference": {
    "inference_mode": "projected",
    "use_projection": true
  },
  "entity_linking": {
    "enabled": true,
    "kb_path": "embedding_evaluation/data/public/entity_linking/ncbi_disease_kb.tsv",
    "queries_path": "embedding_evaluation/data/public/entity_linking/ncbi_disease_test_queries.tsv",
    "cache_dir": "embedding_evaluation/results/cache",
    "normalize": true,
    "rerank_top_k": 50,
    "rerank_alpha": 1.0
  },
  "sts": {
    "enabled": true,
    "pairs_path": "embedding_evaluation/data/public/sts/biosses_test.tsv"
  },
  "nli": {
    "enabled": false,
    "train_path": "embedding_evaluation/data/public/nli/train.tsv",
    "dev_path": "embedding_evaluation/data/public/nli/validation.tsv",
    "test_path": "embedding_evaluation/data/public/nli/validation.tsv",
    "epochs": 20,
    "lr": 0.001,
    "hidden_dim": 128,
    "seed": 42
  }
}
